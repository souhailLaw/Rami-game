<!DOCTYPE html>
<html lang="fr" class="h-full bg-slate-950 text-slate-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Compteur de Rami Sec Universel</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap');
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
  </style>
</head>
<body class="min-h-full py-6 px-4 sm:px-6 lg:px-8 flex flex-col justify-between">

  <div class="max-w-4xl w-full mx-auto space-y-8">
    
    <!-- ================= ÉCRAN 1 : CONFIGURATION DES JOUEURS ================= -->
    <main id="setup-screen" class="max-w-md mx-auto bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-xl space-y-6">
      <div class="text-center space-y-2">
        <span class="text-3xl">🎴</span>
        <h1 class="text-2xl font-extrabold tracking-tight bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">
          Nouvelle Partie de Rami
        </h1>
        <p class="text-xs text-slate-400">Configurez les joueurs pour démarrer la course aux 1000 points.</p>
      </div>

      <!-- Formulaire d'ajout -->
      <div class="space-y-3">
        <label class="block text-xs font-semibold uppercase tracking-wider text-slate-400">Nom du joueur</label>
        <div class="flex gap-2">
          <input type="text" id="player-input" placeholder="Ex: Souhail, Paulo..." class="flex-1 bg-slate-950 border border-slate-800 rounded-xl px-4 py-2.5 text-sm text-slate-200 focus:border-amber-500 focus:outline-none">
          <button onclick="addPlayer()" class="bg-amber-500 hover:bg-amber-400 text-slate-950 font-bold px-4 py-2.5 rounded-xl text-sm transition">
            Ajouter
          </button>
        </div>
      </div>

      <!-- Liste des joueurs ajoutés -->
      <div class="space-y-2">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400">Joueurs sur la ligne de départ :</h3>
        <ul id="setup-players-list" class="divide-y divide-slate-800 border border-slate-800 rounded-xl bg-slate-950/50 overflow-hidden">
          <!-- Généré par JS -->
        </ul>
      </div>

      <!-- BOUTON UNIQUE DE VALIDATION -->
      <button id="start-game-btn" onclick="validateAndStart()" class="w-full py-3 rounded-xl bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-400 hover:to-teal-500 text-white font-bold text-sm shadow-lg shadow-emerald-950/50 transition active:scale-[0.98] disabled:opacity-40 disabled:pointer-events-none">
        🚀 Lancer la partie
      </button>
    </main>

    <!-- ================= ÉCRAN 2 : TABLE DE JEU (CACHÉ AU DÉPART) ================= -->
    <main id="game-screen" class="space-y-8 hidden">
      <!-- Header de jeu -->
      <header class="text-center space-y-2">
        <h1 class="text-3xl font-extrabold tracking-tight text-white">Score en Direct</h1>
        <p class="text-sm text-slate-400">Le premier à atteindre <span class="text-red-400 font-bold">1000 pts</span> a perdu.</p>
      </header>

      <!-- Cartes des Scores -->
      <section id="player-cards" class="grid grid-cols-2 sm:grid-cols-4 gap-4"></section>

      <!-- Zone de validation des manches -->
      <section class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-xl space-y-4">
        <h2 class="text-sm font-bold text-slate-200 uppercase tracking-wider text-slate-400">⚡ Qui a fait Rami Sec ?</h2>
        <div id="action-buttons" class="grid grid-cols-2 sm:grid-cols-4 gap-3"></div>
      </section>

      <!-- Tableau d'historique -->
      <section class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
        <div class="px-6 py-4 border-b border-slate-800 flex justify-between items-center bg-slate-900/50">
          <h3 class="font-bold text-slate-200 text-sm">Historique des Manches</h3>
          <button onclick="undoLastRound()" class="text-xs bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-lg transition">
            ↩️ Annuler la dernière manche
          </button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr id="table-header" class="bg-slate-950/50 text-xs font-semibold uppercase tracking-wider text-slate-400 border-b border-slate-800">
                <!-- Généré dynamiquement -->
              </tr>
            </thead>
            <tbody id="table-body" class="divide-y divide-slate-800/50 text-sm">
              <!-- Généré dynamiquement -->
            </tbody>
          </table>
        </div>
      </section>

      <!-- Quitter la partie -->
      <div class="text-center">
        <button onclick="resetToSetup()" class="text-xs text-red-400 hover:text-red-300 font-semibold bg-red-500/10 border border-red-500/20 px-4 py-2 rounded-xl transition">
          🗑️ Abandonner et créer une nouvelle table
        </button>
      </div>
    </main>

  </div>

  <script>
    // ÉTAT DE L'APPLICATION
    let players = [];
    let rounds = [];

    // --- ÉCRAN 1 : LOGIQUE DE CONFIGURATION ---
    
    // Ajouter un joueur à la liste de préparation
    function addPlayer() {
      const input = document.getElementById('player-input');
      const name = input.value.trim();
      if (name && !players.includes(name)) {
        players.push(name);
        input.value = '';
        renderSetup();
      }
    }

    // Supprimer un joueur de la préparation
    function removePlayer(index) {
      players.splice(index, 1);
      renderSetup();
    }

    // Rendu de l'écran de configuration
    function renderSetup() {
      const list = document.getElementById('setup-players-list');
      const startBtn = document.getElementById('start-game-btn');
      
      list.innerHTML = players.length === 0 
        ? `<li class="p-4 text-center text-xs text-slate-500 italic">Aucun joueur ajouté</li>`
        : players.map((p, idx) => `
            <li class="flex justify-between items-center p-3 text-sm font-medium pl-4">
              <span>${p}</span>
              <button onclick="removePlayer(${idx})" class="text-red-400 hover:text-red-300 text-xs px-2 py-1">Retirer</button>
            </li>
          `).join('');

      // Le bouton unique s'active s'il y a au moins 2 joueurs
      startBtn.disabled = players.length < 2;
    }

    // BOUTON UNIQUE : Validation et bascule vers l'écran de jeu
    function validateAndStart() {
      if (players.length < 2) return;
      
      rounds = []; // Nouvelle partie
      saveToStorage();
      
      // Bascule d'écran
      document.getElementById('setup-screen').classList.add('hidden');
      document.getElementById('game-screen').classList.remove('hidden');
      
      initGameScreen();
    }

    // --- ÉCRAN 2 : LOGIQUE DE JEU ---

    function initGameScreen() {
      // 1. Construire l'en-tête du tableau d'historique
      const header = document.getElementById('table-header');
      header.innerHTML = `<th class="py-4 px-4 text-center w-16">M.</th>` + 
        players.map(p => `<th class="py-4 px-4 text-center">${p}</th>`).join('') +
        `<th class="py-4 px-4 text-center">Gagnant</th>`;

      // 2. Construire les boutons d'action rapide
      const actionZone = document.getElementById('action-buttons');
      actionZone.innerHTML = players.map(p => `
        <button onclick="addRound('${p}')" class="flex flex-col items-center justify-center py-3 bg-slate-800 hover:bg-slate-750 border border-slate-700/60 rounded-xl transition active:scale-95">
          <span class="text-[10px] text-slate-400">Sec pour</span>
          <span class="font-bold text-sm text-white mt-0.5">${p}</span>
        </button>
      `).join('');

      renderGame();
    }

    function addRound(winner) {
      rounds.push({ id: rounds.length + 1, winner: winner });
      saveToStorage();
      renderGame();
    }

    function undoLastRound() {
      if (rounds.length > 0) {
        rounds.pop();
        saveToStorage();
        renderGame();
      }
    }

    // Calculer les scores globaux
    function calculateTotals() {
      const totals = {};
      players.forEach(p => totals[p] = 0);
      
      rounds.forEach(round => {
        players.forEach(p => {
          if (p !== round.winner) totals[p] += 100;
        });
      });
      return totals;
    }

    // Rendu dynamique de la table de jeu et des scores
    function renderGame() {
      const totals = calculateTotals();
      
      // 1. Mettre à jour les fiches/cartes des scores
      const cardsZone = document.getElementById('player-cards');
      cardsZone.innerHTML = players.map(p => {
        const score = totals[p];
        let colorClass = "text-slate-100";
        let bgClass = "bg-slate-900 border-slate-800";
        if (score >= 800) {
          colorClass = "text-red-400 font-bold";
          bgClass = "bg-red-950/20 border-red-900/50 animate-pulse";
        } else if (score >= 500) {
          colorClass = "text-orange-400";
        }
        return `
          <div class="border rounded-xl p-4 text-center space-y-1 ${bgClass}">
            <div class="text-xs text-slate-400 truncate font-semibold">${p}</div>
            <div class="text-2xl font-black ${colorClass}">${score}</div>
          </div>
        `;
      }).join('');

      // 2. Mettre à jour les lignes de l'historique
      const body = document.getElementById('table-body');
      if (rounds.length === 0) {
        body.innerHTML = `<tr><td colspan="${players.length + 2}" class="text-center py-8 text-slate-500 italic text-xs">Aucune manche jouée. Cliquez sur un joueur ci-dessus pour lancer les scores !</td></tr>`;
        return;
      }

      body.innerHTML = [...rounds].reverse().map(round => `
        <tr class="hover:bg-slate-900/40 transition-colors">
          <td class="py-3 px-4 text-center font-bold text-slate-500">M${round.id}</td>
          ${players.map(p => `
            <td class="py-3 px-4 text-center ${p === round.winner ? 'text-emerald-400 font-extrabold' : 'text-slate-400'}">
              ${p === round.winner ? '0' : '+100'}
            </td>
          `).join('')}
          <td class="py-3 px-4 text-center text-amber-400 font-medium text-xs">⭐ ${round.winner}</td>
        </tr>
      `).join('');
    }

    // Retour à l'écran de création
    function resetToSetup() {
      if(confirm("Êtes-vous sûr de vouloir écraser cette partie ?")) {
        players = [];
        rounds = [];
        localStorage.removeItem('rami_universal_state');
        document.getElementById('game-screen').classList.add('hidden');
        document.getElementById('setup-screen').classList.remove('hidden');
        renderSetup();
      }
    }

    // --- PERSISTANCE DES DONNÉES (AUTO-SAVE) ---
    function saveToStorage() {
      localStorage.setItem('rami_universal_state', JSON.stringify({ players, rounds }));
    }

    function loadFromStorage() {
      const saved = localStorage.getItem('rami_universal_state');
      if (saved) {
        try {
          const data = JSON.parse(saved);
          if (data && data.players && data.players.length > 0) {
            players = data.players;
            rounds = data.rounds || [];
            document.getElementById('setup-screen').classList.add('hidden');
            document.getElementById('game-screen').classList.remove('hidden');
            initGameScreen();
            return;
          }
        } catch(e) { console.error("Erreur de récupération", e); }
      }
      renderSetup(); // Si rien n'est sauvegardé, on reste sur l'écran de config
    }

    // Gérer l'appui sur "Entrée" dans l'input
    document.getElementById('player-input').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') addPlayer();
    });

    // Lancement de l'application au chargement
    loadFromStorage();
  </script>
</body>
</html>
